Options -MultiViews
RewriteEngine On
RewriteBase /

# 1. Existierende Dateien direkt ausliefern (.html, .css, .js, Bilder etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Existierende Verzeichnisse direkt ausliefern (Index-Dateien)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Clean URL → .html (z.B. /impressum → impressum.html)
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 4. Alles andere → index.html (SPA Fallback)
RewriteRule ^ index.html [L]
