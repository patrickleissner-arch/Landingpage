Options -MultiViews

# Schutz: interne Entwickler-Dateien nicht oeffentlich ausliefern (403)
# Frontend-Dateien (main.js, chart.umd.js, .css, Bilder, sitemap.xml, robots.txt) bleiben erreichbar.
<FilesMatch "\.(md|json|mjs|env|example|gitignore|gitattributes)$">
    Require all denied
</FilesMatch>
<Files "server.js">
    Require all denied
</Files>

RewriteEngine On
RewriteBase /

# 1. Existierende Dateien direkt ausliefern (.html, .css, .js, Bilder etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Existierende Verzeichnisse direkt ausliefern (Index-Dateien)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Clean URL → .html (z.B. /impressum → impressum.html)
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 4. Alles andere → index.html (SPA Fallback)
RewriteRule ^ index.html [L]
